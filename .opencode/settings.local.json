{
  "permissions": {
    "allow": [
      "mcp__nixos__nix",
      "mcp__nixos__nix_versions"
    ]
  },
  "mcpServers": {
    "obsidian-memory": {
      "env": {
        "OBSIDIAN_API_KEY": "${OBSIDIAN_API_KEY}",
        "OBSIDIAN_PORT": "27124"
      },
      "args": [
        "-y",
        "@dsebastien/obsidian-cli-rest-mcp@latest"
      ],
      "command": "npx"
    },
    "mcp-nixos": {
      "args": [
        "mcp-nixos"
      ],
      "command": "uvx"
    }
  }
}
