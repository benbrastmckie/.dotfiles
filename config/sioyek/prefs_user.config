# Sioyek Configuration - Zathura-inspired theme
# Colors converted from Zathura Gruvbox Light theme

# Theme switching:
# w = Toggle between Gruvbox light (day mode) and Nord dark (night mode)
# Uses external script with state tracking for true toggle behavior
new_command _toggle_theme sioyek-theme-toggle

# Legacy macros (kept for reference/direct access):
# _gruvbox = Gruvbox light (day mode) - cream background
# _nord = Nord dark (night mode) - blue-grey background
new_macro _gruvbox setconfig_custom_background_color(0.922 0.859 0.698);setconfig_custom_text_color(0.235 0.220 0.212)
new_macro _nord setconfig_custom_background_color(0.180 0.204 0.251);setconfig_custom_text_color(0.847 0.871 0.914)

# Empty background color for custom color mode (matches Gruvbox light)
custom_color_mode_empty_background_color 0.922 0.859 0.698

# Set default colors to Nord night mode
background_color 0.180 0.204 0.251

# Dark mode uses Nord
dark_mode_background_color 0.180 0.204 0.251

# Custom colors (Gruvbox Light - cream background, dark text)
custom_background_color 0.922 0.859 0.698
custom_text_color 0.235 0.220 0.212


# UI colors - using Zathura statusbar/inputbar colors
# Zathura: #d5c4a1 -> RGB 0.835, 0.769, 0.631
ui_background_color 0.835 0.769 0.631
ui_text_color 0.235 0.220 0.212

# Selected UI elements - using Zathura highlight blue (#076678 -> RGB 0.027, 0.400, 0.471)
ui_selected_background_color 0.027 0.400 0.471
ui_selected_text_color 0.835 0.769 0.631

# Status bar colors - Nord night mode (when custom colors are off)
status_bar_color 0.145 0.161 0.192
status_bar_text_color 0.847 0.871 0.914

# Highlight colors - using Zathura highlight colors
# Zathura: #b57614 -> RGB 0.710, 0.463, 0.078 (bright yellow)
text_highlight_color 0.710 0.463 0.078
search_highlight_color 0.710 0.463 0.078

# Visual mark color - semi-transparent version of highlight
visual_mark_color 0.710 0.463 0.078 0.3

# Link highlight - using Zathura active highlight (#af3a03 -> RGB 0.686, 0.227, 0.012)
link_highlight_color 0.686 0.227 0.012

# Start with custom colors enabled (Gruvbox Light)
startup_commands toggle_custom_color;turn_on_synctex

# Font and UI settings
font_size 16
status_bar_font_size 16
multiline_menus 1

# Page separation - add minimal gap between pages
page_separator_width 2
page_separator_color 0.5 0.5 0.5

# Inverse search configuration for Neovim integration
# This enables right-click to jump to source in Neovim when SyncTeX is on
inverse_search_command nvim --headless -c "VimtexInverseSearch %2 '%1'"

# Disable external search engines to prevent Ctrl+click Google Scholar
search_url_s ""
search_url_l ""
search_url_g ""
middle_click_search_engine ""

# Configure Ctrl+left-click to trigger inverse search
control_click_command synctex_under_cursor

# Multi-window behavior: open different PDFs in separate windows
# Note: Opening the same PDF will create a duplicate window (native limitation)
# To focus existing window for same file would require a custom wrapper script
should_launch_new_window 1
