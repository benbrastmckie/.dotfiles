{
  "_NOTE": "This file is managed by Home Manager via ~/.dotfiles/config/claude-settings.json (sourced in home.nix). Edit the source file, then run 'home-manager switch'. Runtime changes by Claude Code persist until next rebuild.",
  "env": {
