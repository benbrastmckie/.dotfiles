      "Bash(biber *)",
      "Bash(nix *)",
      "Bash(nixos-rebuild *)",
      "Bash(home-manager *)",
      "Bash(nix-shell *)",
      "Bash(nix-env *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod +x *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Task",
      "TaskCreate",
      "TaskUpdate",
      "Skill",
      "mcp__lean-lsp__*",
      "Bash(echo:*)"
