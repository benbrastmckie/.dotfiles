{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/deepseek-v4-pro",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "https://ollama.com/v1",
        "apiKey": "{env:OLLAMA_API_KEY}"
      },
      "models": {
        "deepseek-v4-pro": { "name": "DeepSeek V4 Pro", "tool_call": true },
        "qwen3": { "name": "Qwen 3", "tool_call": true },
        "llama4-maverick": { "name": "Llama 4 Maverick", "tool_call": true },
        "deepseek-r1": { "name": "DeepSeek R1", "tool_call": true }
      }
    }
  },
  "theme": "gruvbox",
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "keybinds": {
    "leader": "ctrl+d",
    "session_child_cycle": "<leader>j",
    "session_child_cycle_reverse": "<leader>k",
    "session_list": "<leader>s",
    "messages_half_page_down": "alt+j",
    "messages_half_page_up": "alt+k",
    "messages_last": "<leader>l",
    "messages_first": "<leader>h",
    "messages_toggle_conceal": "none",
    "input_newline": "shift+return,ctrl+return,alt+return",
    "input_delete": "delete,shift+delete",
    "session_new": "<leader>n",
    "session_timeline": "<leader>g",
    "session_interrupt": "escape",
    "session_compact": "<leader>c",
    "session_export": "<leader>x",
    "messages_copy": "<leader>y",
    "messages_undo": "<leader>u",
    "messages_redo": "<leader>r",
    "messages_page_up": "pageup",
    "messages_page_down": "pagedown",
    "sidebar_toggle": "<leader>b",
    "theme_list": "<leader>t",
    "model_list": "<leader>m",
    "agent_list": "<leader>a",
    "agent_cycle": "tab",
    "agent_cycle_reverse": "shift+tab",
    "command_list": "ctrl+p",
    "input_clear": "ctrl+c",
    "input_paste": "ctrl+v",
    "input_submit": "return",
    "app_exit": "ctrl+c,<leader>q",
    "editor_open": "<leader>e"
  },
  "default_agent": "logos-coder",
  "mcp": {
    "lean-lsp": {
      "type": "local",
      "command": ["uvx", "lean-lsp-mcp"],
      "environment": {
        "LEAN_LOG_LEVEL": "WARNING"
      }
    }
  }
}
