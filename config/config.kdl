// Request server-side decorations from clients that support them
// This provides consistent window appearance across applications
prefer-no-csd

// Visual and Input Configuration
input {
    keyboard {
        xkb {
            layout "us"
            // Keyboard remapping options
            // caps:swapescape - Swap Escape and Caps Lock keys
            // ctrl:swap_lalt_lctl - Swap left Ctrl and left Alt keys
            options "caps:swapescape,ctrl:swap_lalt_lctl"
        }
        // Faster key repeat for better responsiveness
        repeat-delay 300
        repeat-rate 50
    }

    touchpad {
        natural-scroll
        tap
        // dwt  // Disable while typing - off by default
        accel-profile "adaptive"
        accel-speed 0.2
        scroll-factor 1.2
    }

    mouse {
        // natural-scroll is off by default
        accel-profile "flat"
        accel-speed 0.0
    }
}

// Visual Styling
layout {
    // Modern focus ring appearance
    focus-ring {
        width 3
        active-color "rgb(94, 129, 172)"  // Nord blue
        inactive-color "rgb(67, 76, 94)"   // Nord muted
    }

    // Window borders
    border {
        width 2
        active-color "rgb(94, 129, 172)"    // Nord blue
        inactive-color "rgb(67, 76, 94)"    // Nord muted
    }

    // Workspace layout settings
    gaps 8
    struts {
        left 0
        right 0
        top 32  // Reserve space for top bar
        bottom 0
    }

    // Default window dimensions
    default-column-width { proportion 0.5; }

    // Window shadows for visual depth
    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=5
        color "rgba(0, 0, 0, 0.5)"
    }
}

// Smooth animations
animations {
    // Slower animations off for responsiveness; set to on for smooth
    slowdown 1.0

    // Window animations
    window-open {
        duration-ms 200
        curve "ease-out-expo"
    }
    window-close {
        duration-ms 200
        curve "ease-out-quad"
    }
    window-movement {
        duration-ms 150
        curve "ease-out-cubic"
    }
    window-resize {
        duration-ms 150
        curve "ease-out-cubic"
    }

    // Workspace animations
    horizontal-view-movement {
        duration-ms 200
        curve "ease-out-cubic"
    }
    workspace-switch {
        duration-ms 200
        curve "ease-out-cubic"
    }
}

// Window rules (using window-rule syntax)
// Note: Individual window-rule blocks outside of 'windows' section
// are the modern approach in Niri 25.01+

// WezTerm: Fix initial window size by using proportional column width
window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width { proportion 0.5; }
}

// Firefox PiP windows should float and stay on top
window-rule {
    match title="^Picture-in-Picture$"
    open-floating true
}

// System dialogs (pavucontrol) should float
window-rule {
    match app-id="^pavucontrol$"
    open-floating true
}

// Global window styling - rounded corners for all windows
window-rule {
    geometry-corner-radius 8
    clip-to-geometry true
}

// Steam notification positioning (bottom-right corner)
window-rule {
    match app-id="steam" title=r#"^notificationtoasts_\d+_desktop$"#
    default-floating-position x=10 y=10 relative-to="bottom-right"
}

// Zotero quick citation dialog should float
window-rule {
    match app-id="^Zotero$" title="^Quick Format Citation$"
    open-floating true
}

// GNOME Settings should float
window-rule {
    match app-id="^org\\.gnome\\.Settings$"
    open-floating true
}

//// KEYBINDINGS ////

binds {
    // Program launching
    Mod+T { spawn "kitty"; }
    Mod+B { spawn "brave"; }
    Mod+P { spawn "fuzzel"; }
    Mod+Z { spawn "zotero"; }

    // Quick launchers
    Mod+F { spawn "nautilus"; }  // File manager
    Mod+C { spawn "code"; }      // VSCode
    Mod+M { spawn "spotify"; }   // Music

    // System controls
    Mod+Shift+S { spawn "grimshot" "save" "area"; }  // Screenshot area
    Print { spawn "grimshot" "save" "screen"; }       // Screenshot full
    Mod+Shift+A { spawn "sh" "-c" "grim -g \"$(slurp)\" - | satty -f -"; }  // Screenshot with annotation
    Mod+Shift+X { spawn "swaylock" "-f"; }           // Lock screen

    // Dictation (toggle on/off)
    Mod+D { spawn "whisper-dictate"; }

    // Clipboard history
    Mod+Y { spawn "sh" "-c" "cliphist list | fuzzel --dmenu | cliphist decode | wl-copy"; }

    // Audio controls
    XF86AudioRaiseVolume { spawn "wpctl" "set-volume" "-l" "1.5" "@DEFAULT_AUDIO_SINK@" "5%+"; }
    XF86AudioLowerVolume { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%-"; }
    XF86AudioMute { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    XF86AudioPlay { spawn "playerctl" "play-pause"; }
    XF86AudioNext { spawn "playerctl" "next"; }
    XF86AudioPrev { spawn "playerctl" "previous"; }

    // Window management
    Mod+Q { close-window; }

    // Floating window controls (25.01+)
    Mod+W { toggle-window-floating; }
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }

    // Advanced window management
    Mod+R { switch-preset-column-width; }
    Mod+Shift+M { maximize-column; }
    Mod+Tab { focus-window-previous; }

    // Window focus - vim style
    Mod+H { focus-column-left; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+L { focus-column-right; }

    // Window movement - vim style
    Mod+Shift+H { move-column-left; }
    Mod+Shift+J { move-window-down; }
    Mod+Shift+K { move-window-up; }
    Mod+Shift+L { move-column-right; }

    // Named workspaces
    Mod+1 { focus-workspace "1:web"; }
    Mod+2 { focus-workspace "2:code"; }
    Mod+3 { focus-workspace "3:term"; }
    Mod+4 { focus-workspace "4:docs"; }
    Mod+5 { focus-workspace "5:media"; }
    Mod+6 { focus-workspace "6:chat"; }
    Mod+7 { focus-workspace "7:misc"; }
    Mod+8 { focus-workspace "8:extra"; }
    Mod+9 { focus-workspace "9:bg"; }

    // Move windows to workspaces
    Mod+Shift+1 { move-window-to-workspace "1:web"; }
    Mod+Shift+2 { move-window-to-workspace "2:code"; }
    Mod+Shift+3 { move-window-to-workspace "3:term"; }
    Mod+Shift+4 { move-window-to-workspace "4:docs"; }
    Mod+Shift+5 { move-window-to-workspace "5:media"; }
    Mod+Shift+6 { move-window-to-workspace "6:chat"; }
    Mod+Shift+7 { move-window-to-workspace "7:misc"; }
    Mod+Shift+8 { move-window-to-workspace "8:extra"; }
    Mod+Shift+9 { move-window-to-workspace "9:bg"; }

    // Layout management
    Mod+V { consume-or-expel-window-left; }
    Mod+S { consume-or-expel-window-right; }

    // Niri actions
    Mod+Shift+Q { quit; }
    Mod+Shift+R { power-off-monitors; }
}

//// AUTOSTART PROGRAMS ////

// Note: niri-session-only services (waybar, polkit agent, wallpaper, etc.) are started
// via explicit spawn-at-startup lines below. GNOME session services are unaffected.

// Wallpaper
spawn-at-startup "/run/current-system/sw/bin/swaybg" "-i" "/etc/wallpapers/riverside.jpg" "-m" "fill"

// Status bar
spawn-at-startup "waybar"

// PolicyKit authentication agent (GNOME session uses gnome-shell's own agent)
spawn-at-startup "/run/current-system/sw/bin/polkit-gnome-authentication-agent-1"

// Auto-start kitty terminal
spawn-at-startup "kitty"

// Clipboard history manager (cliphist)
spawn-at-startup "wl-paste" "--type" "text" "--watch" "cliphist" "store"
spawn-at-startup "wl-paste" "--type" "image" "--watch" "cliphist" "store"

// Idle management and auto-lock/suspend
// Lock after 5 min idle, suspend after 10 min, lock before sleep
spawn-at-startup "swayidle" "-w" "timeout" "300" "swaylock -f" "timeout" "600" "systemctl suspend" "before-sleep" "swaylock -f" "lock" "swaylock -f"
